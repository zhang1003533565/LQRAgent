# E2E 测试环境变量（复制为 .env.e2e 或在 shell 中 export）

# 前端 dev 地址（playwright webServer 默认 5173）
E2E_BASE_URL=http://localhost:5173

# 后端 API（用于 API 登录）
E2E_API_URL=http://localhost:8080/api

# 测试学生账号（必填，否则跳过需登录用例）
E2E_USERNAME=student_demo
E2E_PASSWORD=your_password

# 若 frontend 已由外部启动，可设 1 跳过 playwright webServer
# E2E_SKIP_WEB_SERVER=1
